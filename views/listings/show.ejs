<% layout("layouts/boilerplate.ejs") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h1>Listing Details</h1>
        </div>
        <div class=" card col-6 offset-2">
            <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing image" style="height: 20rem;">
            <div class="card-body">
                <p class="card-text">
                    <b>
                        <%= listing.title %>
                    </b><br><br>
                    <b>
                        <%= listing.description %>
                    </b><br>
                    <b>
                        <%= listing.price.toLocaleString("en-IN") %>
                    </b><br>
                    <b>
                        <%= listing.location %>
                    </b><br>
                    <b>
                        <%= listing.country %>
                    </b><br>

                </p>


            </div>


        </div>
        <div class="row">
            <div class=" btn-s col-1 offset-2">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark ">Edit</a><br><br>

                <form method="POST" action="/listings/<%= listing._id %>/delete?_method=DELETE">
                    <button class="btn btn-dark">Delete</button>
                </form>


            </div>

        </div>
         

    </div>
           

