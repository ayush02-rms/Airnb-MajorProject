<% layout("layouts/boilerplate.ejs") %>

    <body>

        <div class="row">

            <div class="col-8 offset-2">
                <br>
                <br>


                <h1>Create new listing</h1>

                <form method="POST" action="/listings">

                    <div class="mb-3">
                        <label for="title" class="form-label">Title:</label>
                        <input type="text" name="listing[title]" id="title" placeholder="write your title"
                            class="form-control">
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description:</label>
                        <textarea name="listing[description]" id="description" placeholder="write your description"
                            class="form-control"></textarea>

                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Image URL:</label>
                        <input type="text" name="listing[image]" id="image" placeholder="Image URL"
                            class="form-control">

                    </div>
                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-label">Price:</label>
                            <input type="number" name="listing[price]" id="price" placeholder="write your price"
                                class="form-control">

                        </div>
                        <div class="mb-3 col-8">
                            <label for="country" class="form-label">Country:</label>
                            <input type="text" name="listing[country]" id="country" placeholder="write your country"
                                class="form-control">
                        </div>

                    </div>


                    <div class="mb-3">
                        <label for="location" class="form-label">Location:</label>
                        <input type="text" name="listing[location]" id="location" placeholder="write your location"
                            class="form-control">
                    </div>





                    <button type="submit" class="btn btn-dark add-btn">Add Listing</button>
                </form>
                <br>


            </div>

        </div>

    </body>

    </html>